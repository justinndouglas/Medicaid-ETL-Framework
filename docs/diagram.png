limit\":2,\"history_results_limit\":6},\"is_device_based\":false,\"passed\":false},\"2850107578\":{\"name\":\"2850107578\",\"rule_id\":\"7nxmtzMrThjQ6ucoe2XHVB:100.00:20-7nxmty7pqZalN4EsCV24Cz\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"ask_chatgpt_system_message\":\"The user is referring to an ad shown to them about: {LABEL}. Your response MUST BE ABOUT THE ADS shown, since the user explicitly asked about them. They are using the 'Ask ChatGPT' feature and you must reply to the user query using the information about the ads, which is:\\n{DATA}\\n\\nFor example: if the user asks 'Tell me more about these' (or other wordings), then your answer should be about details or further information on products, services, locations etc described in the ad and the links in the ad.\",\"onboarding\":{\"screen_trust_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/trusted_en.png\",\"screen_privacy_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/secure.png\",\"screen_transparency_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/controls_en.png\",\"screen_personalization_image_url\":\"https://cdn.openai.com/chatgpt/clients/bazaar/onboarding/personalization_en.png\",\"impression_count\":5,\"card_image_url\":\"https://cdn.openai.com/chatgpt/clients/onboarding/onboarding-example-1.png\"},\"android_large_font_scale_threshold\":1.5,\"android_display_zoom_scale_threshold\":1,\"late_ads_event_discard_timeout_after_message_end_visibility_seconds\":3.5,\"late_ads_event_discard_timeout_seconds\":5},\"is_device_based\":false,\"passed\":true},\"301381018\":{\"name\":\"301381018\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"2604379743\":{\"name\":\"2604379743\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"nux_video_url\":\"https://persistent.oaistatic.com/image-gen/nux.CB3699EE.mov\",\"nux_image_url\":\"https://persistent.oaistatic.com/image-gen/nux.CB3699EE.jpg\"},\"is_device_based\":false,\"passed\":false},\"349697204\":{\"name\":\"349697204\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"changelog_url\":\"https://help.openai.com/en/articles/11428266-codex-changelog\",\"availability_message_type\":\"available_to_plus_pro_team_enterprise_and_edu\",\"changelog_date\":\"2025-06-13\",\"upgrade_button_message_type\":\"upgrade_to_try_it\",\"codex_mini_models\":[{\"label\":\"GPT-5.5\",\"value\":\"gpt-5.5\"},{\"value\":\"gpt-5.4\",\"label\":\"GPT-5.4\"}]},\"is_device_based\":true,\"passed\":false},\"2358948225\":{\"name\":\"2358948225\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2888003541\":{\"name\":\"2888003541\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_bytes\":31457280},\"is_device_based\":false,\"passed\":false},\"3055066993\":{\"name\":\"3055066993\",\"rule_id\":\"layerAssignment\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":true,\"is_user_in_experiment\":false},\"1535193150\":{\"name\":\"1535193150\",\"rule_id\":\"7n9WKSvKgoVDgGzElXY3QT\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"show_turn_search_sources\":false,\"render_web_results_like_files\":true,\"show_web_page_file_refs\":true,\"file_ref_type_order\":[\"grouped_webpages\",\"webpage_extended\",\"file\"],\"journal_homepage_url_icon_enabled\":true},\"is_device_based\":false,\"passed\":true},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"enable_web_search\":false},\"is_device_based\":false,\"passed\":false},\"3747383021\":{\"name\":\"3747383021\",\"rule_id\":\"7cvBu4nR7a9tVSNBIeCzCV:100.00:1\",\"secondary_exposures\":[{\"gate\":\"733205176\",\"gateValue\":\"true\",\"ruleID\":\"64zSpYdNz3zRgulUhRHj86:100.00:13\"}],\"id_type\":\"stableID\",\"value\":{\"teams\":true,\"google_calendar\":true,\"sharepoint\":true,\"outlook_email\":true,\"mcp\":true,\"google_drive\":true,\"linear\":true,\"box\":true,\"gmail\":true,\"slack\":true,\"outlook_calendar\":true,\"github\":true,\"dropbox\":true,\"notion\":true,\"canva\":true,\"hubspot\":true},\"is_