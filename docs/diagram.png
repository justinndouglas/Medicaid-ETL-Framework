/*# sourceMappingURL=data:application/json;base64, */</style><style>.ai-suggestion-adjust-button {
    height: 24px;
    padding: 1.5px 8px;
    background-color: #0c6fc6;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 11px;
    font-weight: bold;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

.ai-suggestion-adjust-button:disabled {
    cursor: not-allowed;
    opacity: 0.6;
}

.ai-suggestion-adjust-button:not(:disabled):hover {
    background-color: #0a5ba8;
}

.ai-suggestion-adjust-button:not(:disabled):active {
    background-color: #084f91;
}

